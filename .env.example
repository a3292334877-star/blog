# Supabase 访客计数
# 注册 https://supabase.com 后，从 Settings > API 复制
# 后端表、RLS 与 RPC 均确认可用后再改为 true；默认关闭以避免失败请求。
VITE_VISITOR_COUNTER_ENABLED=false
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Giscus 评论
# 访问 https://giscus.app/zh-CN 获取（需先开启仓库 Discussions 并安装 Giscus App）
VITE_GISCUS_REPO_ID=your-repo-id
VITE_GISCUS_CATEGORY_ID=your-category-id

# ============================================================
# 线上部署（GitHub Pages）配置
# ============================================================
# .env 已被 gitignore，不会进仓库，因此 GitHub Actions 构建时读不到。
# 需要在仓库 Settings → Secrets and variables → Actions 添加以下 4 个 secrets：
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY
#   VITE_GISCUS_REPO_ID
#   VITE_GISCUS_CATEGORY_ID
# 访客统计修复后，可另加 Repository variable：VITE_VISITOR_COUNTER_ENABLED=true。
# deploy.yml 的 build 步骤已配置从 secrets / variables 读取这些值注入 env。
